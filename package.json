{
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@types/express": "^5.0.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "diff": "^8.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "formidable": "^3.5.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "next": "^16.1.6",
    "pdf-parse": "^1.1.1",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/formidable": "^3.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfmake": "^0.3.1",
    "@types/react": "19.2.14",
    "concurrently": "^8.2.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "dev:backend": "tsx src/index.ts",
    "dev:process-api": "next dev -p 3002",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:process-api\" \"npm run dev:frontend\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  }
}
